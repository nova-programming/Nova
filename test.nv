def add(a, b) {
    return a + b
}

def multiply(a, b) {
    return a * b
}

def factorial(n) {
    result = 1
    i = 1
    while i <= n {
        result = result * i
        i = i + 1
    }
    return result
}

def fibonacci(n) {
    a = 0
    b = 1
    i = 0
    while i < n {
        temp = a
        a = b
        b = temp + b
        i = i + 1
    }
    return a
}

def is_prime(n) {
    if n <= 1 {
        return 0
    }
    i = 2
    while i * i <= n {
        if n % i == 0 {
            return 0
        }
        i = i + 1
    }
    return 1
}

def gcd(a, b) {
    while b != 0 {
        temp = b
        b = a % b
        a = temp
    }
    return a
}

def sum_range(start, end) {
    total = 0
    i = start
    while i <= end {
        total = total + i
        i = i + 1
    }
    return total
}

print("=== ADD ===")
print(add(10, 20))

print("=== MULTIPLY ===")
print(multiply(5, 6))

print("=== FACTORIAL 5 ===")
print(factorial(5))

print("=== FIBONACCI 0-9 ===")
i = 0
while i < 10 {
    print(fibonacci(i))
    i = i + 1
}

print("=== PRIME NUMBERS UP TO 30 ===")
i = 2
while i <= 30 {
    if is_prime(i) {
        print(i)
    }
    i = i + 1
}

print("=== GCD ===")
print(gcd(48, 18))
print(gcd(100, 25))

print("=== SUM 1-100 ===")
print(sum_range(1, 100))

print("=== NESTED LOOPS ===")
i = 0
while i < 3 {
    j = 0
    while j < 3 {
        print(i * 10 + j)
        j = j + 1
    }
    i = i + 1
}

print(999)