# ============================================================
# Nova Comprehensive Test Suite (test.nv)
# Tests: variables, arithmetic, control flow, functions,
#        loops, break/continue, strings, nested logic
# ============================================================

# ---- 1. Variables and Arithmetic ----
mut x = 10
mut y = 20
mut z = x + y * 2
print(z)

mut a = 100 - 30
mut b = a / 7
print(a)
print(b)

mut c = 17 % 5
print(c)

# ---- 2. String operations ----
mut greeting = "Hello Nova!"
print(greeting)

# ---- 3. If/Else ----
mut score = 85
if score >= 90 {
    print("Grade: A")
} else {
    if score >= 80 {
        print("Grade: B")
    } else {
        print("Grade: F")
    }
}

# ---- 4. While loop ----
mut counter = 0
mut sum = 0
while counter < 10 {
    sum = sum + counter
    counter = counter + 1
}
print(sum)

# ---- 5. For loop (counting up) ----
mut total = 0
for i = 1 to 5 {
    total = total + i
}
print(total)

# ---- 6. For loop with step ----
mut evens = 0
for i = 0 to 10 step 2 {
    evens = evens + i
}
print(evens)

# ---- 7. Break and Continue ----
mut found = 0
mut idx = 0
while idx < 100 {
    if idx == 42 {
        found = idx
        break
    }
    idx = idx + 1
}
print(found)

mut odd_sum = 0
for i = 1 to 20 {
    if i % 2 == 0 {
        continue
    }
    odd_sum = odd_sum + i
}
print(odd_sum)

# ---- 8. Functions ----
def add(a: int, b: int) -> int {
    return a + b
}

def multiply(a: int, b: int) -> int {
    return a * b
}

print(add(3, 7))
print(multiply(6, 8))

# ---- 9. Factorial (iterative) ----
def factorial(n: int) -> int {
    mut result = 1
    mut i = 2
    while i <= n {
        result = result * i
        i = i + 1
    }
    return result
}
print(factorial(5))

# ---- 10. Nested functions ----
def max_val(a: int, b: int) -> int {
    if a > b {
        return a
    }
    return b
}

def min_val(a: int, b: int) -> int {
    if a < b {
        return a
    }
    return b
}

def clamp(val: int, lo: int, hi: int) -> int {
    return max_val(lo, min_val(val, hi))
}

print(clamp(150, 0, 100))
print(clamp(-5, 0, 100))
print(clamp(50, 0, 100))

# ---- 11. Fibonacci (iterative) ----
def fib(n: int) -> int {
    if n <= 1 {
        return n
    }
    mut a = 0
    mut b = 1
    mut i = 2
    while i <= n {
        mut temp = a + b
        a = b
        b = temp
        i = i + 1
    }
    return b
}

for i = 0 to 10 {
    print(fib(i))
}

# ---- 12. Complex expression ----
mut complex = (10 + 20) * 3 - (50 / 5) + 7 % 3
print(complex)

# ---- 13. Fizzbuzz (1-15) ----
for i = 1 to 15 {
    if i % 15 == 0 {
        print("FizzBuzz")
    } else {
        if i % 3 == 0 {
            print("Fizz")
        } else {
            if i % 5 == 0 {
                print("Buzz")
            } else {
                print(i)
            }
        }
    }
}

# ---- 14. Logical operators ----
mut p1 = 1
mut p2 = 0
if p1 and not p2 {
    print("Logic OK")
}

# ---- 15. Unary negation ----
mut neg = -42
print(neg)

# ---- 16. Nested while with break ----
mut outer = 0
while outer < 5 {
    mut inner = 0
    while inner < 5 {
        if inner == 3 {
            break
        }
        inner = inner + 1
    }
    outer = outer + 1
}
print(outer)

print("All tests completed!")
