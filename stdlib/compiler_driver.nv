import compiler

args = sys_get_args()
if len(args) < 2 {
    print("Usage: compiler <input_file.nv>")
} else {
    input_path = args[1]
    out_len = len(input_path)
    output_path = input_path + ".s"
    if out_len > 3 {
        ext = str_sub(input_path, out_len - 3, 3)
        if ext == ".nv" {
            output_path = str_sub(input_path, 0, out_len - 3) + ".s"
        }
    }
    compile_to_file(input_path, output_path)
}
