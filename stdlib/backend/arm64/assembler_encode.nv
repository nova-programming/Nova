def encode_csel(state, ops: list) {
    xd = parse_operand(ops[0])
    xn = parse_operand(ops[1])
    xm = parse_operand(ops[2])
    cond_name = ops[3]
    cc = cond_code(cond_name)
    sf = 1
    if xd.width == 32 { sf = 0 }
    rd = xd.reg
    rn = xn.reg
    rm = xm.reg
    base = 0x9A800000
    if sf == 0 { base = 0x1A800000 }
    val = base | (1 << 21) | (rm << 16) | (1 << 15) | (1 << 14) | ((cc >> 3) << 13) | (((cc >> 2) & 1) << 12) | (1 << 11) | (((cc >> 1) & 1) << 10) | (rn << 5) | rd
    asm_append_u32(state, val)
}

def encode_cset(state, ops: list) {
    xd = parse_operand(ops[0])
    cond_name = ops[1]
    cc = cond_code(cond_name)
    inv_cc = cc ^ 1
    sf = 1
    if xd.width == 32 { sf = 0 }
    rd = xd.reg
    base = 0x9A800000
    if sf == 0 { base = 0x1A800000 }
    val = base | (31 << 16) | ((inv_cc >> 3) << 13) | (((inv_cc >> 2) & 1) << 12) | (1 << 11) | (((inv_cc >> 1) & 1) << 10) | (31 << 5) | rd
    asm_append_u32(state, val)
}

def encode_mem_ldr_str(state, size_code: int, is_load: int, ops: list) {
    rt = parse_operand(ops[0])
    mem = parse_operand(ops[1])
    post_imm = 0
    post_mode = 0
    if len(ops) >= 3 {
        post_op = parse_operand(ops[2])
        if post_op.kind == "imm" {
            post_imm = post_op.imm_val
            post_mode = 1
        }
    }
    if mem.kind != "mem" { return }
    if mem.mem_offset_reg >= 0 {
        option = 3
        if size_code == 0 {
            base = 0x38200000
            if is_load == 0 { base = 0x38200000 }
        }
        if size_code == 1 {
            base = 0x78600000
            if is_load == 0 { base = 0x78200000 }
        }
        if size_code == 2 {
            base = 0xB8600000
            if is_load == 0 { base = 0xB8200000 }
        }
        if size_code == 3 {
            base = 0xF8600000
            if is_load == 0 { base = 0xF8200000 }
        }
        val = base | (mem.mem_offset_reg << 16) | (option << 13) | (mem.mem_offset_shift << 12) | (2 << 10) | (mem.mem_base << 5) | rt.reg
        asm_append_u32(state, val)
        return
    }
    rn = mem.mem_base
    imm = mem.mem_disp
    use_wb = mem.writeback
    if post_mode == 1 {
        imm = post_imm
        use_wb = 2
    }
    scale = 0
    if size_code == 0 { scale = 0 }
    if size_code == 1 { scale = 1 }
    if size_code == 2 { scale = 2 }
    if size_code == 3 { scale = 3 }
    if use_wb == 0 and imm >= 0 {
        scaled = imm / (1 << scale)
        base = 0x39400000
        if size_code == 1 { base = 0x79400000 }
        if size_code == 2 { base = 0xB9400000 }
        if size_code == 3 { base = 0xF9400000 }
        if is_load == 0 {
            if size_code == 0 { base = 0x39000000 }
            if size_code == 1 { base = 0x79000000 }
            if size_code == 2 { base = 0xB9000000 }
            if size_code == 3 { base = 0xF9000000 }
        }
        val = base | ((scaled & 0xFFF) << 10) | (rn << 5) | rt.reg
        asm_append_u32(state, val)
        return
    }
    base = 0x38400000
    if size_code == 1 { base = 0x78400000 }
    if size_code == 2 { base = 0xB8400000 }
    if size_code == 3 { base = 0xF8400000 }
    if is_load == 0 {
        if size_code == 0 { base = 0x38000000 }
        if size_code == 1 { base = 0x78000000 }
        if size_code == 2 { base = 0xB8000000 }
        if size_code == 3 { base = 0xF8000000 }
    }
    if use_wb == 1 {
        base = base | (1 << 23)
    }
    if use_wb == 2 {
        base = base | (1 << 24)
    }
    val = base | ((imm & 0x1FF) << 12) | (rn << 5) | rt.reg
    asm_append_u32(state, val)
}

def encode_ldr(state, ops: list) {
    rt = parse_operand(ops[0])
    if rt.width == 64 or rt.width == 0 {
        encode_mem_ldr_str(state, 3, 1, ops)
    } else {
        encode_mem_ldr_str(state, 2, 1, ops)
    }
}

def encode_str(state, ops: list) {
    rt = parse_operand(ops[0])
    if rt.width == 64 or rt.width == 0 {
        encode_mem_ldr_str(state, 3, 0, ops)
    } else {
        encode_mem_ldr_str(state, 2, 0, ops)
    }
}

def encode_ldrb(state, ops: list) {
    encode_mem_ldr_str(state, 0, 1, ops)
}

def encode_strb(state, ops: list) {
    encode_mem_ldr_str(state, 0, 0, ops)
}

def encode_ldrh(state, ops: list) {
    encode_mem_ldr_str(state, 1, 1, ops)
}

def encode_strh(state, ops: list) {
    encode_mem_ldr_str(state, 1, 0, ops)
}

def encode_ldp(state, ops: list) {
    rt1 = parse_operand(ops[0])
    rt2 = parse_operand(ops[1])
    mem = parse_operand(ops[2])
    imm = mem.mem_disp
    rn = mem.mem_base
    imm7 = imm / 8
    base = 0xA9400000
    if mem.writeback == 1 { base = 0xA9C00000 }
    if mem.writeback == 2 { base = 0xA8C00000 }
    val = base | ((imm7 & 0x7F) << 15) | (rt2.reg << 10) | (rn << 5) | rt1.reg
    asm_append_u32(state, val)
}

def encode_stp(state, ops: list) {
    rt1 = parse_operand(ops[0])
    rt2 = parse_operand(ops[1])
    mem = parse_operand(ops[2])
    imm = mem.mem_disp
    rn = mem.mem_base
    imm7 = imm / 8
    base = 0xA9000000
    if mem.writeback == 1 { base = 0xA9800000 }
    if mem.writeback == 2 { base = 0xA8800000 }
    val = base | ((imm7 & 0x7F) << 15) | (rt2.reg << 10) | (rn << 5) | rt1.reg
    asm_append_u32(state, val)
}

def encode_adrp(state, ops: list) {
    xd = parse_operand(ops[0])
    label_op = parse_operand(ops[1])
    rd = xd.reg
    off = len(state.code)
    asm_append_u32(state, 0x90000000 | rd)
    add_fixup(state, off, label_op.label, 5)
}

def encode_b(state, ops: list) {
    label_op = parse_operand(ops[0])
    off = len(state.code)
    asm_append_u32(state, 0x14000000)
    add_fixup(state, off, label_op.label, 4)
}

def encode_bl(state, ops: list) {
    label_op = parse_operand(ops[0])
    off = len(state.code)
    asm_append_u32(state, 0x94000000)
    add_fixup(state, off, label_op.label, 4)
}

def encode_bcond(state, ops: list) {
    label_op = parse_operand(ops[0])
    off = len(state.code)
    cc = 0
    if len(ops) >= 2 {
        cond_name = ops[1]
        cc = cond_code(cond_name)
    }
    asm_append_u32(state, 0x54000000 | cc)
    add_fixup(state, off, label_op.label, 7)
}

def encode_fadd(state, ops: list) {
    rd = parse_operand(ops[0])
    rn = parse_operand(ops[1])
    rm = parse_operand(ops[2])
    val = 0x1E602800 | (rm.reg << 16) | (rn.reg << 5) | rd.reg
    asm_append_u32(state, val)
}

