}

def encode_fcmp(state, ops: list) {
    rn = parse_operand(ops[0])
    rm = parse_operand(ops[1])
    val = 0x1EC03800 | (rm.reg << 16) | (rn.reg << 5)
    asm_append_u32(state, val)
}

def emit_instruction(state, line: AsmLine) {
    if line.mnemonic == "add" {
        if len(line.operands) == 3 {
            op2 = parse_operand(line.operands[2])
            if op2.kind == "imm" or op2.kind == "lo12_label" {
                encode_add_imm(state, line.operands)
            } else {
                encode_add_reg(state, line.operands)
            }
        }
        return
    }
    if line.mnemonic == "sub" {
        if len(line.operands) == 3 {
            op2 = parse_operand(line.operands[2])
            if op2.kind == "imm" {
                encode_sub_imm(state, line.operands)
            } else {
                encode_sub_reg(state, line.operands)
            }
        }
        return
    }
    if line.mnemonic == "and" {
        op2 = parse_operand(line.operands[2])
        if op2.kind == "imm" {
            encode_and_imm(state, line.operands)
        } else {
            encode_and_reg(state, line.operands)
        }
        return
    }
    if line.mnemonic == "orr" {
        encode_orr_reg(state, line.operands)
        return
    }
    if line.mnemonic == "eor" {
        encode_eor_reg(state, line.operands)
        return
    }
    if line.mnemonic == "cmp" {
        op1 = parse_operand(line.operands[1])
        if op1.kind == "imm" {
            encode_cmp_imm(state, line.operands)
        } else {
            encode_cmp_reg(state, line.operands)
        }
        return
    }
    if line.mnemonic == "mov" {
        encode_mov_reg(state, line.operands)
        return
    }
    if line.mnemonic == "mul" {
        encode_mul(state, line.operands)
        return
    }
    if line.mnemonic == "msub" {
        encode_msub(state, line.operands)
        return
    }
    if line.mnemonic == "sdiv" {
        encode_sdiv(state, line.operands)
        return
    }
    if line.mnemonic == "lsl" {
        op2 = parse_operand(line.operands[2])
        if op2.kind == "imm" {
            encode_lsl_imm(state, line.operands)
        } else {
            encode_lsl_reg(state, line.operands)
        }
        return
    }
    if line.mnemonic == "asr" {
        encode_asr_reg(state, line.operands)
        return
    }
    if line.mnemonic == "mvn" {
        encode_mvn(state, line.operands)
        return
    }
    if line.mnemonic == "neg" {
        encode_neg(state, line.operands)
        return
    }
    if line.mnemonic == "csel" {
        encode_csel(state, line.operands)
        return
    }
    if line.mnemonic == "cset" {
        encode_cset(state, line.operands)
        return
    }
    if line.mnemonic == "ldr" {
        encode_ldr(state, line.operands)
        return
    }
    if line.mnemonic == "str" {
        encode_str(state, line.operands)
        return
    }
    if line.mnemonic == "ldrb" {
        encode_ldrb(state, line.operands)
        return
    }
    if line.mnemonic == "strb" {
        encode_strb(state, line.operands)
        return
    }
    if line.mnemonic == "ldrh" {
        encode_ldrh(state, line.operands)
        return
    }
    if line.mnemonic == "strh" {
        encode_strh(state, line.operands)
        return
    }
    if line.mnemonic == "ldp" {
        encode_ldp(state, line.operands)
        return
    }
    if line.mnemonic == "stp" {
        encode_stp(state, line.operands)
        return
    }
    if line.mnemonic == "adrp" {
        encode_adrp(state, line.operands)
        return
    }
    if line.mnemonic == "b" {
        encode_b(state, line.operands)
        return
    }
    if line.mnemonic == "bl" {
        encode_bl(state, line.operands)
        return
    }
    if len(line.mnemonic) >= 3 and line.mnemonic[0] == "b" and line.mnemonic[1] == "." {
        cond_str = line.mnemonic
        cond_name = cond_str
        cond_len = len(cond_str)
        cond_code_val = 0
        if cond_len >= 3 and cond_str[0] == "b" and cond_str[1] == "." {
            cc_name = ""
            i = 2
            while i < cond_len {
                cc_name = cc_name + cond_str[i]
                i = i + 1
            }
            cond_code_val = cond_code(cc_name)
        }
        label_op = parse_operand(line.operands[0])
        off = len(state.code)
        asm_append_u32(state, 0x54000000 | cond_code_val)
        add_fixup(state, off, label_op.label, 7)
        return
    }
    if line.mnemonic == "fadd" {
        encode_fadd(state, line.operands)
        return
    }
    if line.mnemonic == "fsub" {
        encode_fsub(state, line.operands)
        return
    }
    if line.mnemonic == "fmul" {
        encode_fmul(state, line.operands)
        return
    }
    if line.mnemonic == "fdiv" {
        encode_fdiv(state, line.operands)
        return
    }
    if line.mnemonic == "fcmp" {
        encode_fcmp(state, line.operands)
        return
    }
    if line.mnemonic == "ret" {
        asm_append_u32(state, 0xD65F03C0)
        return
    }
}
