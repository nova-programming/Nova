    rd = parse_operand(ops[0])
    rn = parse_operand(ops[1])
    rm = parse_operand(ops[2])
    val = 0x1E606800 | (rm.reg << 16) | (rn.reg << 5) | rd.reg
    asm_append_u32(state, val)
}

