def cond_code(name: string) -> int {
    if name == "eq" { return 0 }
    if name == "ne" { return 1 }
    if name == "cs" or name == "hs" { return 2 }
    if name == "cc" or name == "lo" { return 3 }
    if name == "mi" { return 4 }
    if name == "pl" { return 5 }
    if name == "vs" { return 6 }
    if name == "vc" { return 7 }
    if name == "hi" { return 8 }
    if name == "ls" { return 9 }
    if name == "ge" { return 10 }
    if name == "lt" { return 11 }
    if name == "gt" { return 12 }
    if name == "le" { return 13 }
    if name == "al" { return 14 }
    return 0
}

def asm_append_u32(state, val: int) {
    state.code.append(val % 256)
    val = val / 256
    state.code.append(val % 256)
    val = val / 256
    state.code.append(val % 256)
    val = val / 256
    state.code.append(val % 256)
}

def add_fixup(state, offset: int, target: string, size: int) {
    fix = Fixup()
    fix.offset = offset
    fix.target = target
    fix.size = size
    state.fixups.append(fix)
}

def encode_add_imm(state, ops: list) {
    xd = parse_operand(ops[0])
    xn = parse_operand(ops[1])
    if len(ops) == 3 and ops[2][0] == ":" {
        imm_op = parse_operand(ops[2])
        sf = 1
        if xd.width == 32 { sf = 0 }
        rd = xd.reg
        rn = xn.reg
        base = 0x91000000
        if sf == 0 { base = 0x11000000 }
        val = base | (rn << 5) | rd
        add_fixup(state, len(state.code), imm_op.label, 6)
        asm_append_u32(state, val)
        return
    }
    imm_op = parse_operand(ops[2])
    sf = 1
    if xd.width == 32 { sf = 0 }
    rd = xd.reg
    rn = xn.reg
    imm = imm_op.imm_val
    shift = 0
    if imm > 4095 and imm % 4096 == 0 {
        shift = 1
        imm = imm / 4096
    }
    base = 0x91000000
    if sf == 0 { base = 0x11000000 }
    val = base | (shift << 22) | ((imm & 0xFFF) << 10) | (rn << 5) | rd
    asm_append_u32(state, val)
}

def encode_sub_imm(state, ops: list) {
    xd = parse_operand(ops[0])
    xn = parse_operand(ops[1])
    imm_op = parse_operand(ops[2])
    sf = 1
    if xd.width == 32 { sf = 0 }
    rd = xd.reg
    rn = xn.reg
    imm = imm_op.imm_val
    shift = 0
    if imm > 4095 and imm % 4096 == 0 {
        shift = 1
        imm = imm / 4096
    }
    base = 0xD1000000
    if sf == 0 { base = 0x51000000 }
    val = base | (shift << 22) | ((imm & 0xFFF) << 10) | (rn << 5) | rd
    asm_append_u32(state, val)
}

def encode_bitmask_enc(val: int, sf: int) -> int {
    bits = 64
    if sf == 0 { bits = 32 }
    v = val
    if sf == 0 { v = v & 0xFFFFFFFF }
    if v == 0 { return 0 - 1 }
    all_ones = 1
    b = 0
    while b < bits {
        if v >> b & 1 == 0 { all_ones = 0; break }
        b = b + 1
    }
    if all_ones == 1 { return 0 - 1 }
    size = 2
    while size <= bits {
        mask = (1 << size) - 1
        pat = v & mask
        repeats = 1
        pos = size
        while pos < bits {
            if (v >> pos) & mask != pat { repeats = 0; break }
            pos = pos + size
        }
        if repeats == 1 and pat != 0 and pat != mask {
            rot = 0
            while rot < size {
                ror_val = ((pat >> rot) | (pat << (size - rot))) & mask
                if (ror_val & (ror_val + 1)) == 0 and ror_val != 0 {
                    k = 0
                    tv = ror_val
                    while tv != 0 { k = k + 1; tv = tv & (tv - 1) }
                    immr = rot
                    if size == bits {
                        N = 1
                        imms = k - 1
                    } else {
                        N = 0
                        e = 0
                        ts = size
                        while ts > 1 { ts = ts / 2; e = e + 1 }
                        sel_bits = 5
                        if sf == 0 { sel_bits = 4 }
                        imms = (((1 << (sel_bits - e)) - 1) << e) | (k - 1)
                    }
                    return (N << 22) | (immr << 16) | ((imms & 0x3F) << 10)
                }
                rot = rot + 1
            }
        }
        size = size * 2
    }
    return 0 - 1
}

def encode_and_imm(state, ops: list) {
    xd = parse_operand(ops[0])
    xn = parse_operand(ops[1])
    imm_op = parse_operand(ops[2])
    sf = 1
    if xd.width == 32 { sf = 0 }
    rd = xd.reg
    rn = xn.reg
    imm = imm_op.imm_val
    encoded = encode_bitmask_enc(imm, sf)
    if encoded >= 0 {
        base = 0x92000000
        if sf == 0 { base = 0x12000000 }
        val = base | encoded | (rn << 5) | rd
        asm_append_u32(state, val)
    }
}

def encode_cmp_imm(state, ops: list) {
    xn = parse_operand(ops[0])
    imm_op = parse_operand(ops[1])
    sf = 1
    if xn.width == 32 { sf = 0 }
    rn = xn.reg
    imm = imm_op.imm_val
    shift = 0
    if imm > 4095 and imm % 4096 == 0 {
        shift = 1
        imm = imm / 4096
    }
    base = 0xF1000000
    if sf == 0 { base = 0x71000000 }
    val = base | (shift << 22) | ((imm & 0xFFF) << 10) | (rn << 5) | 31
    asm_append_u32(state, val)
}

def encode_mov_imm(state, ops: list) {
    xd = parse_operand(ops[0])
    imm_op = parse_operand(ops[1])
    if imm_op.kind != "imm" { return }
    sf = 1
    if xd.width == 32 { sf = 0 }
    rd = xd.reg
    imm = imm_op.imm_val
    hw = 0
    remaining = imm
    if sf == 0 { remaining = remaining % 65536 }
    base = 0xD2800000
    if sf == 0 { base = 0x52800000 }
    val = base | (hw << 21) | ((remaining & 0xFFFF) << 5) | rd
    asm_append_u32(state, val)
}

