    sf = 1
    if xd.width == 32 { sf = 0 }
    rd = xd.reg
    rn = xn.reg
    rm = xm.reg
    ra = xa.reg
    base = 0x9B000000
    if sf == 0 { base = 0x1B000000 }
    val = base | (rm << 16) | (ra << 10) | (rn << 5) | rd
    asm_append_u32(state, val)
}

