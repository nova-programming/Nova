def encode_cmp_reg(state, ops: list) {
    xn = parse_operand(ops[0])
    xm = parse_operand(ops[1])
    sf = 1
    if xn.width == 32 { sf = 0 }
    rn = xn.reg
    rm = xm.reg
    base = 0xEB000000
    if sf == 0 { base = 0x6B000000 }
    val = base | (rm << 16) | (rn << 5) | 31
    asm_append_u32(state, val)
}

def encode_mov_reg(state, ops: list) {
    if len(ops) == 1 {
        xd = parse_operand(ops[0])
        rd = xd.reg
        val = 0xAA0003E0 | rd
        asm_append_u32(state, val)
        return
    }
    xd = parse_operand(ops[0])
    src = parse_operand(ops[1])
    if src.kind == "imm" {
        encode_mov_imm(state, ops)
        return
    }
    sf = 1
    if xd.width == 32 { sf = 0 }
    rd = xd.reg
    rm = src.reg
    base = 0xAA0003E0
    if sf == 0 { base = 0x2A0003E0 }
    val = base | (rm << 16) | rd
    asm_append_u32(state, val)
}

