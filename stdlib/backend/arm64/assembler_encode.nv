def encode_lsl_reg(state, ops: list) {
    xd = parse_operand(ops[0])
    xn = parse_operand(ops[1])
    xm = parse_operand(ops[2])
    sf = 1
    if xd.width == 32 { sf = 0 }
    rd = xd.reg
    rn = xn.reg
    rm = xm.reg
    base = 0x9AC08000
    if sf == 0 { base = 0x1AC08000 }
    val = base | (rm << 16) | (rn << 5) | rd
    asm_append_u32(state, val)
}

def encode_lsl_imm(state, ops: list) {
    xd = parse_operand(ops[0])
    xn = parse_operand(ops[1])
    imm_op = parse_operand(ops[2])
    sf = 1
    if xd.width == 32 { sf = 0 }
    rd = xd.reg
    rn = xn.reg
    s = imm_op.imm_val
    if sf == 0 {
        immr = (32 - s) & 31
        imms = (31 - s) & 31
        val = 0x53000000 | (immr << 16) | (imms << 10) | (rn << 5) | rd
    } else {
        immr = (64 - s) & 63
        imms = (63 - s) & 63
        val = 0xD3800000 | (immr << 16) | (imms << 10) | (rn << 5) | rd
    }
    asm_append_u32(state, val)
}

