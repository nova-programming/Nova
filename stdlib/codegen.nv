    emit(state, "push 0")
    emit(state, "mov eax, [ebp + 8]")
    emit(state, "push eax")
    emit(state, "call _fseek")
    emit(state, "add esp, 12")
    emit(state, "push eax")
    emit(state, "pop eax")
    emit(state, "# line 14")
    emit(state, "mov ebx, 1")
    emit(state, "mov eax, esi")
    emit(state, "add eax, ebx")
    emit(state, "push eax")
    emit(state, "call _malloc")
    emit(state, "add esp, 4")
