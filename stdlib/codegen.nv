    emit(state, "    mov eax, [ebp + 12]")
    emit(state, "    imul eax, [ebp + 16]")
    emit(state, "    push eax")
    emit(state, "    push dword ptr [ebp + 8]")
    emit(state, "    push dword ptr [ebp + 20]")
    emit(state, "    call ReadFile")
    emit(state, "    mov eax, [ebp - 4]")
    emit(state, "    mov esp, ebp")
    emit(state, "    pop ebp")
    emit(state, "    ret")
    emit(state, "")
    emit(state, "_fputs:")
    emit(state, "    push ebp")
    emit(state, "    mov ebp, esp")
    emit(state, "    push ebx")
    emit(state, "    sub esp, 4")
    emit(state, "    push dword ptr [ebp + 8]")
    emit(state, "    call _strlen")
    emit(state, "    add esp, 4")
    emit(state, "    mov ebx, eax")
    emit(state, "    push 0")
    emit(state, "    lea eax, [ebp - 4]")
    emit(state, "    push eax")
    emit(state, "    push ebx")
    emit(state, "    push dword ptr [ebp + 8]")
    emit(state, "    push dword ptr [ebp + 12]")
    emit(state, "    call WriteFile")
    emit(state, "    mov eax, [ebp - 4]")
    emit(state, "    mov esp, ebp")
    emit(state, "    pop ebp")
    emit(state, "    ret")
    emit(state, "")
    emit(state, "_fputc:")
    emit(state, "    push ebp")
    emit(state, "    mov ebp, esp")
    emit(state, "    sub esp, 8")
    emit(state, "    mov eax, [ebp + 8]")
    emit(state, "    mov byte ptr [ebp - 4], al")
    emit(state, "    lea eax, [ebp - 8]")
    emit(state, "    push 0")
    emit(state, "    push eax")
    emit(state, "    push 1")
    emit(state, "    lea eax, [ebp - 4]")
    emit(state, "    push eax")
    emit(state, "    push dword ptr [ebp + 12]")
    emit(state, "    call WriteFile")
    emit(state, "    mov eax, [ebp - 8]")
    emit(state, "    mov esp, ebp")
    emit(state, "    pop ebp")
    emit(state, "    ret")
    emit(state, "")
    emit(state, "_fwrite:")
    emit(state, "    push ebp")
    emit(state, "    mov ebp, esp")
    emit(state, "    sub esp, 4")
    emit(state, "    mov eax, [ebp + 12]")
    emit(state, "    imul eax, [ebp + 16]")
    emit(state, "    push 0")
    emit(state, "    lea ecx, [ebp - 4]")
    emit(state, "    push ecx")
    emit(state, "    push eax")
    emit(state, "    push dword ptr [ebp + 8]")
    emit(state, "    push dword ptr [ebp + 20]")
    emit(state, "    call WriteFile")
    emit(state, "    mov eax, [ebp - 4]")
    emit(state, "    mov esp, ebp")
    emit(state, "    pop ebp")
    emit(state, "    ret")
    emit(state, "")
    emit(state, "_fseek:")
    emit(state, "    push ebp")
    emit(state, "    mov ebp, esp")
    emit(state, "    push dword ptr [ebp + 16]")
    emit(state, "    push 0")
    emit(state, "    push dword ptr [ebp + 12]")
    emit(state, "    push dword ptr [ebp + 8]")
    emit(state, "    call SetFilePointer")
    emit(state, "    xor eax, eax")
    emit(state, "    pop ebp")
    emit(state, "    ret")
    emit(state, "")
    emit(state, "_ftell:")
    emit(state, "    push ebp")
    emit(state, "    mov ebp, esp")
    emit(state, "    push 1")
    emit(state, "    push 0")
    emit(state, "    push 0")
    emit(state, "    push dword ptr [ebp + 8]")
    emit(state, "    call SetFilePointer")
    emit(state, "    pop ebp")
    emit(state, "    ret")
    emit(state, "")
    emit(state, "_fflush:")
    emit(state, "    push ebp")
    emit(state, "    mov ebp, esp")
    emit(state, "    mov eax, [ebp + 8]")
    emit(state, "    test eax, eax")
    emit(state, "    jz L_fflush_done")
    emit(state, "    push eax")
    emit(state, "    call FlushFileBuffers")
    emit(state, "L_fflush_done:")
    emit(state, "    pop ebp")
    emit(state, "    ret")
    emit(state, "")
    # Process
    emit(state, "_exit:")
    emit(state, "    push ebp")
    emit(state, "    mov ebp, esp")
    emit(state, "    push dword ptr [ebp + 8]")
    emit(state, "    call ExitProcess")
    emit(state, "L_exit_never:")
    emit(state, "    pop ebp")
    emit(state, "    ret")
    emit(state, "")
    emit(state, "_system:")
    emit(state, "    push ebp")
    emit(state, "    mov ebp, esp")
    emit(state, "    push 1")
    emit(state, "    push dword ptr [ebp + 8]")
    emit(state, "    call WinExec")
    emit(state, "    pop ebp")
    emit(state, "    ret")
}

# --- Main entry point ---

def generate_assembly(ast: list, debug_mode: int) -> list {
    state = new_codegen()

    emit(state, ".intel_syntax noprefix")
    emit(state, ".global _main")
    emit(state, ".extern GetProcessHeap")
    emit(state, ".extern HeapAlloc")
    emit(state, ".extern HeapFree")
    emit(state, ".extern HeapReAlloc")
    emit(state, ".extern GetStdHandle")
    emit(state, ".extern WriteFile")
    emit(state, ".extern ReadFile")
    emit(state, ".extern CreateFileA")
    emit(state, ".extern CloseHandle")
    emit(state, ".extern SetFilePointer")
    emit(state, ".extern FlushFileBuffers")
    emit(state, ".extern ExitProcess")
    emit(state, ".extern WinExec")
    emit(state, ".extern _GetCommandLineA")

    emit_data(state, "fmt_int: .asciz \"%d\\n\"")
    emit_data(state, "fmt_int_pure: .asciz \"%d\"")
    emit_data(state, "fmt_str: .asciz \"%s\\n\"")
    emit_data(state, "fmt_float: .asciz \"%f\\n\"")
    emit_data(state, "fmt_float_pure: .asciz \"%f\"")
    emit_data(state, "debug_prefix: .asciz \"debug - [line \"")
    emit_data(state, "debug_suffix: .asciz \"]: \"")
    emit_data(state, "L_out_of_bounds_msg: .asciz \"Index Out Of Bounds\\n\"")

    emit_data(state, "char_strings:")
    char_idx = 0
    while char_idx < 256 {
        emit_data(state, "    .byte " + str(char_idx))
        emit_data(state, "    .byte 0")
        char_idx = char_idx + 1
    }

    emit(state, ".text")

    functions = []
    top_level = []
    i = 0
    while i < len(ast) {
        node = ast[i]
        if node.kind == "Function" {
            functions.append(node)
        } else {
            if node.kind == "Data" {
                state.struct_names.append(node.val_str)
                state.struct_fields.append([])
                max_off = 0
                j = 0
                while j < len(node.params) {
                    off = get_prop_offset(state, node.val_str, node.params[j])
                    if off + 4 > max_off {
                        max_off = off + 4
                    }
                    j = j + 1
                }
                if max_off == 0 {
                    max_off = 4
                }
                state.struct_sizes.append(max_off)
            } else {
                top_level.append(node)
            }
        }
        i = i + 1
    }

    i_f = 0
    while i_f < len(functions) {
        compile_function(state, functions[i_f], debug_mode)
        i_f = i_f + 1
    }

    state.local_var_names = []
    state.local_vars = []
    state.local_var_regs = []
    state.local_offset = 0
    state.used_regs = []
    state.reg_pool_idx = 0
    
    i = 0
    while i < len(top_level) {
        scan_vars(state, top_level[i])
        i = i + 1
    }

    emit(state, "_main:")
    emit(state, "    push ebp")
    emit(state, "    mov ebp, esp")
    if state.local_offset > 0 {
        emit(state, "    sub esp, " + str(state.local_offset))
    }
    
    r = 0
    while r < len(state.used_regs) {
        emit(state, "    push " + state.used_regs[r])
        r = r + 1
    }

    i = 0
    while i < len(top_level) {
        compile_stmt(state, top_level[i], debug_mode)
        i = i + 1
    }
    
    r = len(state.used_regs) - 1
    while r >= 0 {
        emit(state, "    pop " + state.used_regs[r])
        r = r - 1
    }
    emit(state, "    mov esp, ebp")
    emit(state, "    pop ebp")
    emit(state, "    mov eax, 0")
    emit(state, "    ret")

    emit(state, "_concat_strings:")
    emit(state, "    push ebp")
    emit(state, "    mov ebp, esp")
    emit(state, "    push ebx")
    emit(state, "    push dword ptr [ebp+8]")
    emit(state, "    call _strlen")
    emit(state, "    add esp, 4")
    emit(state, "    mov ebx, eax")
    emit(state, "    push dword ptr [ebp+12]")
    emit(state, "    call _strlen")
    emit(state, "    add esp, 4")
    emit(state, "    add ebx, eax")
    emit(state, "    add ebx, 1")
    emit(state, "    push ebx")
    emit(state, "    call _malloc")
    emit(state, "    add esp, 4")
    emit(state, "    push eax")
    emit(state, "    push dword ptr [ebp+8]")
    emit(state, "    push eax")
    emit(state, "    call _strcpy")
    emit(state, "    add esp, 8")
    emit(state, "    pop eax")
    emit(state, "    push eax")
    emit(state, "    push dword ptr [ebp+12]")
    emit(state, "    push eax")
    emit(state, "    call _strcat")
    emit(state, "    add esp, 8")
    emit(state, "    pop eax")
    emit(state, "    pop ebx")
    emit(state, "    pop ebp")
    emit(state, "    ret")

    emit(state, "_slice_string:")
    emit(state, "    push ebp")
    emit(state, "    mov ebp, esp")
    emit(state, "    push esi")
    emit(state, "    push edi")
    emit(state, "    push ebx")
    emit(state, "    mov esi, [ebp+8]")
    emit(state, "    mov ebx, [ebp+12]")
    emit(state, "    mov ecx, [ebp+16]")
    emit(state, "    sub ecx, ebx")
    emit(state, "    cmp ecx, 0")
    emit(state, "    jge L_slice_alloc")
    emit(state, "    mov ecx, 0")
    emit(state, "L_slice_alloc:")
    emit(state, "    push ecx")
    emit(state, "    inc ecx")
    emit(state, "    push ecx")
    emit(state, "    call _malloc")
    emit(state, "    add esp, 4")
    emit(state, "    pop ecx")
    emit(state, "    mov edi, eax")
    emit(state, "    add esi, ebx")
    emit(state, "    push edi")
    emit(state, "    push ecx")
    emit(state, "    cmp ecx, 0")
    emit(state, "    jle L_slice_done")
    emit(state, "L_slice_copy:")
    emit(state, "    mov al, [esi]")
    emit(state, "    mov [edi], al")
    emit(state, "    inc esi")
    emit(state, "    inc edi")
    emit(state, "    dec ecx")
    emit(state, "    cmp ecx, 0")
    emit(state, "    jg L_slice_copy")
    emit(state, "L_slice_done:")
    emit(state, "    pop ecx")
    emit(state, "    pop edi")
    emit(state, "    mov byte ptr [edi + ecx], 0")
    emit(state, "    mov eax, edi")
    emit(state, "    pop ebx")
    emit(state, "    pop edi")
    emit(state, "    pop esi")
    emit(state, "    pop ebp")
    emit(state, "    ret")

    emit_win32_runtime(state)

    final_asm = []
    i = 0
    while i < len(state.asm_lines) {
        final_asm.append(state.asm_lines[i])
        i = i + 1
    }
    final_asm.append(".data")
    i = 0
    while i < len(state.data_lines) {
        final_asm.append(state.data_lines[i])
        i = i + 1
    }

    return final_asm
}
