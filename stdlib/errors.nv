def err(err_type: string, filename: string, line: int, msg: string, suggestion: string, col: int) {
    if filename != "" {
        print("ERROR [" + filename + ":" + str(line) + ":" + str(col) + "] (" + err_type + "): " + msg)
    } else {
        print("ERROR [line " + str(line) + ":" + str(col) + "] (" + err_type + "): " + msg)
    }
    print("  -> " + suggestion)
    sys_flush()
}

def warn(err_type: string, filename: string, line: int, msg: string, suggestion: string, col: int) {
    if filename != "" {
        print("WARNING [" + filename + ":" + str(line) + ":" + str(col) + "] (" + err_type + "): " + msg)
    } else {
        print("WARNING [line " + str(line) + ":" + str(col) + "] (" + err_type + "): " + msg)
    }
    print("  -> " + suggestion)
    sys_flush()
}
