# Debug test: manually check chacha buffer after each step
# We'll use __get_word to read output words

chacha20_init(42, 1337)
print("init done\n")

# Manually call chacha20_block
# After this, buffer bytes 64-127 should have the block output
call _chacha20_block
print("block done\n")

# Now call __get_word(0) through __get_word(3) manually
# by calling random() which should use the new block
# We need to reset the index first though... 
# Actually random() will check index >= 16, and it's 16
# so it will generate ANOTHER block and use word 0

r1 = random()
print("r1 = ")
print(r1)
print("\n")

# Now index is 1, should use word 1 from the block
r2 = random()
print("r2 = ")
print(r2)
print("\n")
