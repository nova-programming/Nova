# Test bitwise operators
a = 10  # 0b1010
b = 3   # 0b0011

# &
c_and = a & b
print("a & b = ")
print(c_and)
print(" (expected 2)\n")

# |
c_or = a | b
print("a | b = ")
print(c_or)
print(" (expected 11)\n")

# ^
c_xor = a ^ b
print("a ^ b = ")
print(c_xor)
print(" (expected 9)\n")

# ~
c_not = ~a
print("~a = ")
print(c_not)
print("\n")

# <<
c_shl = a << 2
print("a << 2 = ")
print(c_shl)
print(" (expected 40)\n")

# >>
c_shr = a >> 1
print("a >> 1 = ")
print(c_shr)
print(" (expected 5)\n")

# Combined
c_comb = (a ^ b) | (a & b) << 1
print("combined = ")
print(c_comb)
print("\n")
