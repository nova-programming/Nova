x = 3.14

@raw {
    # Print the address of fmt_float as an integer
    push offset fmt_float
    push eax           # stack adjusted, keep alignment
    push offset fmt_int_pure
    call _printf
    add esp, 8
    push 0
    call _fflush
    add esp, 4
    
    # Now print x
    mov eax, [ebp - 4]
    push eax
    push offset fmt_float
    call _printf
    add esp, 8
    push 0
    call _fflush
    add esp, 4
}

print("done")
