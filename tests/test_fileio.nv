print("Starting File I/O test...")
file1 = openf("tests/test_fileio_output.txt")
file1.write("Hello World!\n")
print("After write")
file1.awrite("Appending line 2!\n")
print("After awrite")
file1.close()
print("After close 1")

file2 = openf("tests/test_fileio_output.txt")
content = file2.read()
print("File contents:")
print(content)
file2.close()
print("Test completed.")
