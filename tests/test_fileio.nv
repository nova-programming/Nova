print("Starting File I/O test...")
file1 = openf("tests/test_fileio_output.txt", "w")
print("file1 fd:")
print(file1.fd)
file1.write("Hello World!\n")
print("After write")
file1.close()

file1a = openf("tests/test_fileio_output.txt", "a")
print("file1a fd:")
print(file1a.fd)
file1a.awrite("Appending line 2!\n")
print("After awrite")
file1a.close()
print("After close 1")

file2 = openf("tests/test_fileio_output.txt", "r")
content = file2.read()
print("File contents:")
print(content)
file2.close()
print("Test completed.")

