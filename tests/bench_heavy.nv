def sum_to(n) {
    s = 0
    i = 0
    while i <= n {
        s = s + i
        i = i + 1
    }
    return s
}

def is_prime(n) {
    if n < 2 { return 0 }
    i = 2
    while i * i <= n {
        if n % i == 0 { return 0 }
        i = i + 1
    }
    return 1
}

def count_primes(limit) {
    count = 0
    i = 2
    while i <= limit {
        if is_prime(i) == 1 { count = count + 1 }
        i = i + 1
    }
    return count
}

# fib for heavy recursion test
def fib(n) {
    if n <= 1 { return n }
    return fib(n - 1) + fib(n - 2)
}

# sum 1..10 million
print(sum_to(10000000))
print(" ")

# count primes up to 50000
print(count_primes(50000))
print(" ")

# fib(35)
print(fib(35))
print("\n")
