import lexer
import parser
import os_win

fd = sys_open("stdlib/compiler.nv", "r")
src = sys_read(fd)
sys_close(fd)

tokens = tokenize(src)
ast = parse(tokens)

count = 0
i = 0
while i < len(ast) {
    if ast[i].kind == "Function" {
        count = count + 1
    }
    i = i + 1
}

print("Functions found: ")
print(str(count) + "\n")
print("Total AST nodes: ")
print(str(len(ast)) + "\n")

i = 0
while i < len(ast) {
    print("Node " + str(i) + ": kind=" + ast[i].kind)
    if ast[i].kind == "Function" {
        print(" name=" + ast[i].val_str)
    }
    print("\n")
    i = i + 1
}
