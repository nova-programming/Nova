x = 10

# Test 1: x << 2 (variable, leaf-to-reg)
y1 = x << 2
print("y1 = ")
print(y1)
print("\n")

# Test 2: constant << constant
y2 = 10 << 2
print("y2 = ")
print(y2)
print("\n")

# Test 3: constant << variable
z = 2
y3 = 10 << z
print("y3 = ")
print(y3)
print("\n")

# Test 4: variable << variable
y4 = x << z
print("y4 = ")
print(y4)
print("\n")
