import assembler

asm_lines = []
i = 0
while i < 500 {
    asm_lines.append("  mov eax, [ebx + ecx * 4]")
    asm_lines.append("  add eax, edx")
    asm_lines.append("  cmp al, 0")
    asm_lines.append("  je _label_" + str(i))
    asm_lines.append("  inc eax")
    asm_lines.append("_label_" + str(i) + ":")
    asm_lines.append("  mov [edi + eax], al")
    i = i + 1
}
asm_lines.append("  ret")

print("Generated " + str(len(asm_lines)) + " lines\n")
result = assembler.assemble(asm_lines)
print("Done: " + str(len(result)) + " sections\n")
