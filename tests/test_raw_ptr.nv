import os_win

def run_test() {
    print("--- Testing @raw blocks and Pointers ---\n")
    sys_flush()
    
    @raw {
        # Allocate 16 bytes of raw memory
        ptr = sys_alloc(16)
        
        # 1. DWord (4-byte) usage
        ptr.value = 123456789
        (ptr + 4).value = 987654321
        
        v1 = ptr.value
        v2 = (ptr + 4).value
        
        print("DWord at ptr: " + str(v1) + "\n")
        print("DWord at ptr+4: " + str(v2) + "\n")
        
        # 3. Byte (1-byte) usage
        (ptr + 8).value_byte = 65  # 'A'
        (ptr + 9).value_byte = 66  # 'B'
        
        b1 = (ptr + 8).value_byte
        b2 = (ptr + 9).value_byte
        print("Byte at ptr+8: " + str(b1) + "\n")
        print("Byte at ptr+9: " + str(b2) + "\n")
        
        # Free memory
        sys_free(ptr)
        print("Memory freed successfully.\n")
    }
    
    print("--- Raw pointer tests completed ---\n")
    sys_flush()
}

run_test()
