# Nova System — Overall Performance Benchmark
# Workloads tuned for VM (~2s wall time)

def sum_to(n) {
    s = 0
    i = 1
    while i <= n {
        s = s + i
        i = i + 1
    }
    return s
}

def is_prime(n) {
    if n < 2 { return 0 }
    i = 2
    while i * i <= n {
        if n % i == 0 { return 0 }
        i = i + 1
    }
    return 1
}

def count_primes(limit) {
    count = 0
    i = 2
    while i <= limit {
        if is_prime(i) == 1 { count = count + 1 }
        i = i + 1
    }
    return count
}

def fib(n) {
    if n <= 1 { return n }
    return fib(n - 1) + fib(n - 2)
}

w_sum_to = 100000
w_primes = 5000
w_fib = 23

print(sum_to(w_sum_to))
print(count_primes(w_primes))
print(fib(w_fib))
