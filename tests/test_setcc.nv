def main() {
    x = 10
    y = 5
    if x < y {
        print(0)
    } else {
        print(1)
    }
    if x <= y {
        print(0)
    } else {
        print(1)
    }
    if x > y {
        print(1)
    } else {
        print(0)
    }
    if x >= y {
        print(1)
    } else {
        print(0)
    }
    if x == y {
        print(0)
    } else {
        print(1)
    }
    if x != y {
        print(1)
    } else {
        print(0)
    }
    print(x < y)
    print(x <= y)
    print(x > y)
    print(x >= y)
    print(x == y)
    print(x != y)
}
main()
