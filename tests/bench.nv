# Nova Benchmarks - timed individually
# Each test runs standalone so we can time it externally

def fib(n) {
    if n <= 1 { return n }
    return fib(n - 1) + fib(n - 2)
}

def sum_to(n) {
    s = 0
    i = 0
    while i <= n {
        s = s + i
        i = i + 1
    }
    return s
}

def is_prime(n) {
    if n < 2 { return 0 }
    i = 2
    while i * i <= n {
        if n % i == 0 { return 0 }
        i = i + 1
    }
    return 1
}

def count_primes(limit) {
    count = 0
    i = 2
    while i <= limit {
        if is_prime(i) == 1 { count = count + 1 }
        i = i + 1
    }
    return count
}

def list_build(n) {
    items = []
    i = 0
    while i < n {
        items.append(i)
        i = i + 1
    }
    return items
}

def list_sum(items) {
    s = 0
    i = 0
    while i < len(items) {
        s = s + items[i]
        i = i + 1
    }
    return s
}

def float_chain(n) {
    x = 0.0
    i = 0
    while i < n {
        x = x + 3.14159
        x = x * 0.9999
        i = i + 1
    }
    return x
}

print("=== Nova Benchmarks ===\n")

print("1. Fibonacci(30)...\n")
print(fib(30))
print("\n")

print("2. Sum 1..100000...\n")
print(sum_to(100000))
print("\n")

print("3. Count primes up to 10000...\n")
print(count_primes(10000))
print("\n")

print("4. Float chain 100000x...\n")
print(float_chain(100000))
print("\n")

print("5. Build list of 10000...\n")
items = list_build(10000)
print("  len=")
print(len(items))
print("  sum=")
print(list_sum(items))
print("\n")

print("=== Done ===\n")
