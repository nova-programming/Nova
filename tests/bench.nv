# Nova Benchmarks with ChaCha20 Random
# Timed using GetTickCount (milliseconds)

import os_win
import math_utils

def fib(n) {
    if n <= 1 { return n }
    return fib(n - 1) + fib(n - 2)
}

def sum_to(n) {
    s = 0
    i = 0
    while i <= n {
        s = s + i
        i = i + 1
    }
    return s
}

def is_prime(n) {
    if n < 2 { return 0 }
    i = 2
    while i * i <= n {
        if n % i == 0 { return 0 }
        i = i + 1
    }
    return 1
}

def count_primes(limit) {
    count = 0
    i = 2
    while i <= limit {
        if is_prime(i) == 1 { count = count + 1 }
        i = i + 1
    }
    return count
}

def float_chain(n) {
    x = 0.0
    i = 0
    while i < n {
        x = x + 3.14159
        x = x * 0.9999
        i = i + 1
    }
    return x
}

def bench_fib() {
    print("[1] Fibonacci(35)...")
    t0 = sys_get_tick_count()
    r = fib(35)
    t1 = sys_get_tick_count()
    print("    t0 = " + str(t0))
    print("    t1 = " + str(t1))
    print("    result = " + str(r))
    print("    time   = " + str(t1 - t0) + " ms")
    print("")
}

def bench_sum() {
    print("[2] Sum 1..1,000,000...")
    t0 = sys_get_tick_count()
    r = sum_to(1000000)
    t1 = sys_get_tick_count()
    print("    result = " + str(r))
    print("    time   = " + str(t1 - t0) + " ms")
    print("")
}

def bench_primes() {
    print("[3] Count primes up to 10,000...")
    t0 = sys_get_tick_count()
    r = count_primes(10000)
    t1 = sys_get_tick_count()
    print("    result = " + str(r))
    print("    time   = " + str(t1 - t0) + " ms")
    print("")
}

def bench_float() {
    print("[4] Float chain 100,000x...")
    t0 = sys_get_tick_count()
    r = float_chain(100000)
    t1 = sys_get_tick_count()
    print("    result = " + str(r))
    print("    time   = " + str(t1 - t0) + " ms")
    print("")
}

def bench_random_1m() {
    print("[5] ChaCha20 PRNG: 1,000,000 random numbers...")
    chacha20_init(42, 1337)
    last = 0
    t0 = sys_get_tick_count()
    i = 0
    while i < 1000000 {
        last = random()
        i = i + 1
    }
    t1 = sys_get_tick_count()
    dt = t1 - t0
    print("    last   = " + str(last))
    print("    time   = " + str(dt) + " ms")
    if dt > 0 {
        print("    rate   = " + str(1000 / dt) + " M rng/sec")
    }
    print("")
}

def bench_random_10m() {
    print("[6] ChaCha20 PRNG: 10,000,000 random numbers...")
    chacha20_init(999, 7777)
    last = 0
    t0 = sys_get_tick_count()
    i = 0
    while i < 10000000 {
        last = random()
        i = i + 1
    }
    t1 = sys_get_tick_count()
    dt = t1 - t0
    print("    last   = " + str(last))
    print("    time   = " + str(dt) + " ms")
    if dt > 0 {
        print("    rate   = " + str(10000 / dt) + " M rng/sec")
    }
    print("")
}

def run_benchmarks() {
    print("========================================")
    print("  Nova Benchmark Suite v2.0")
    print("  (with ChaCha20 CSPRNG)")
    print("========================================")
    print("")

    bench_fib()
    bench_sum()
    bench_primes()
    bench_float()
    bench_random_1m()
    bench_random_10m()

    print("========================================")
    print("  Benchmark Complete")
    print("========================================")
}

run_benchmarks()
