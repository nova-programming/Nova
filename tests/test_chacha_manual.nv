chacha20_init(42, 1337)
call _chacha20_block

# Now call __get_word(0) through __get_word(3) to check first 4 output words
i = 0
while i < 4 {
    # Nova doesn't allow calling __ functions directly, 
    # so let's use random() which should work
    r = random()
    print("r[")
    print(i)
    print("] = ")
    print(r)
    print("\n")
    i = i + 1
}
