def fib(n) {
    if n <= 1 { return n }
    return fib(n - 1) + fib(n - 2)
}

def sum_to(n) {
    s = 0
    i = 0
    while i <= n {
        s = s + i
        i = i + 1
    }
    return s
}

def is_prime(n) {
    if n < 2 { return 0 }
    i = 2
    while i * i <= n {
        if n % i == 0 { return 0 }
        i = i + 1
    }
    return 1
}

def count_primes(limit) {
    count = 0
    i = 2
    while i <= limit {
        if is_prime(i) == 1 { count = count + 1 }
        i = i + 1
    }
    return count
}

print("[1] fib(35)...\n")
t0 = sys_get_tick_count()
r = fib(35)
t1 = sys_get_tick_count()
print("    result = ")
print(r)
print("\n    time   = ")
print(t1 - t0)
print(" ms\n\n")

print("[2] sum_to(10,000,000)...\n")
t0 = sys_get_tick_count()
r = sum_to(10000000)
t1 = sys_get_tick_count()
print("    result = ")
print(r)
print("\n    time   = ")
print(t1 - t0)
print(" ms\n\n")

print("[3] count_primes(50,000)...\n")
t0 = sys_get_tick_count()
r = count_primes(50000)
t1 = sys_get_tick_count()
print("    result = ")
print(r)
print("\n    time   = ")
print(t1 - t0)
print(" ms\n\n")

print("[4] sum_to(100,000,000)...\n")
t0 = sys_get_tick_count()
r = sum_to(100000000)
t1 = sys_get_tick_count()
print("    result = ")
print(r)
print("\n    time   = ")
print(t1 - t0)
