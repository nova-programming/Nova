def sys_get_tick_count() -> int { return 0 }
def chacha20_init(seed1: int, seed2: int) {}
def _get_idx() -> int { return 0 }
def _set_idx(v: int) {}
def chacha20_block() {}
def _get_word(idx: int) -> int { return 0 }

def random() -> int {
    idx = _get_idx()
    if idx > 1000 {
        tick = sys_get_tick_count()
        chacha20_init(tick, tick)
        idx = _get_idx()
    }
    if idx >= 16 {
        chacha20_block()
        idx = 0
    }
    val = _get_word(idx)
    _set_idx(idx + 1)
    return val
}
